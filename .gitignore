.env
__pycache__/
*.pyc
.DS_Store

# Data files: ignore raw/processed contents (huge + PHI), keep folder
# structure via .gitkeep so the layout is reproducible.
# Pattern is hospital-agnostic: any *-raw/ or *-processed/ under any hospital.
data_process/*/*-raw/*
!data_process/*/*-raw/.gitkeep
data_process/*/*-processed/*
!data_process/*/*-processed/.gitkeep

# Results: track all CSVs / JSONs / PNGs / agent_io_logs (small, useful for
# analysis), but ignore model checkpoints (.pt files in checkpoint_mlm/) since
# they're large + regenerable by re-pretraining.
results/*/checkpoint_mlm/*
!results/*/checkpoint_mlm/.gitkeep
