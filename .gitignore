.env
__pycache__/
*.pyc
.DS_Store
.ipynb_checkpoints/

# Data files: ignore raw/processed contents (huge + PHI), keep folder
# structure via .gitkeep so the layout is reproducible.
# Pattern is hospital-agnostic: any *-raw/ or *-processed/ under any hospital.
data_process/*/*-raw/*
!data_process/*/*-raw/.gitkeep
data_process/*/*-processed/*
!data_process/*/*-processed/.gitkeep

# Results: do NOT track any per-run artifacts.
# Reason: on HPC the smoke writes to /blue (per RESULTS_ROOT in sbatch); on Mac
# the smoke writes to local /Users/.../results. Tracking either copy causes pull
# conflicts whenever HPC and Mac diverge, and accumulates dead artifacts in repo
# (300+ files, 14M+ over time). Final paper figures go in analyze/ (separate dir).
# Keep .gitkeep files so the empty directory structure is reproducible.
results/**
!results/.gitkeep
!results/**/.gitkeep

# Slurm logs — never track (job-specific, regenerable)
slurm_logs/**
!slurm_logs/.gitkeep
slurm-*.out
slurm-*.err

# Analyze: track plot scripts (.py) but NOT generated outputs.
# Same rationale as results/**: Mac dev and HPC production both write here,
# causing pull conflicts and pollution. Final paper figures live on /blue
# (per ANALYZE_DIR in sbatch) or local /Users/.../analyze on Mac.
analyze/*.csv
analyze/*.png
analyze/*.json
!analyze/.gitkeep

# Mac-only smoke scripts (hardcoded /Users/.../MAS-NAS path). HPC uses
# smoke_test_hipergator_xhospital.sbatch instead — no point shipping these.
smoke_test_mac.sh
smoke_test_mac_xhospital.sh
